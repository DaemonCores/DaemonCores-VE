#!/bin/bash
#
# fanctl — generic self-calibrating fan controller over local IPMI
#
# Usage: fanctl [--daemon|--check|--calibrate|--restore|--once]
#   --daemon     Run the control loop (default when no argument is given).
#   --check      Print discovered sensors, fans, vendor and current metrics.
#   --calibrate  Force a calibration pass, persist the result, and exit.
#   --restore    Hand fan regulation back to the BMC (automatic) and exit.
#   --once       Print one metrics line and exit.
#
# How it works:
#   Each temperature sensor is classified (by chip + label) into a component
#   profile with two SOURCED values: an optimal TARGET and a hard-safety CRIT
#   (see classify_sensor). Cool-preferring parts (CPU/GPU/VRM/RAM/battery) get a
#   low target; warm-preferring parts (SSD/HDD) a higher one. The auto-calibrated
#   fan curve tracks, in real time, the component that is furthest above ITS OWN
#   target -- so every part is held at its optimal temperature, all the time.
#
#   Calibration measures the real thermal response of THIS machine by its
#   DERIVATIVE: at each fan speed it watches whether the driving component rises,
#   falls or holds over a window (dT/dt), not a single instant, and converges to
#   the speed that holds it stable at its target. It also records the lowest speed
#   that keeps the volatile part from climbing -- the constant floor (CAL_FLOOR)
#   the machine idles at, so it settles at one level instead of oscillating. In
#   normal operation a per-component DEAD ZONE around the target keeps the fans
#   steady through noise (no yoyo); only past that does the speed nudge, and past
#   the wider RECAL band the curve is recalibrated (also on inlet shift, and
#   immediately -- as sheer evidence -- if any knee is reached).
#
#   Two hard thresholds sit above the target, both bare (no margin) and both
#   meant never to trigger in normal use. KNEE: T >= knee forces fans to 100%
#   (longevity). SURVIVAL (the hardware Tjmax): if temperature still climbs past
#   it -- cooling has truly failed -- a last-resort escalation warns the user at
#   +5, powers off cleanly at +8, and cuts power violently (SysRq o) at +12.
#   The escalation keys off SURVIVAL, never the knee, so a normal load spike
#   never powers the machine off. Ambient/inlet sensors are reference only.
#   Writing the fan speed uses an auto-detected vendor profile (ipmitool mc info)
#   on IPMI, ectool on a ChromeOS/Framework EC, or hwmon PWM; an unknown IPMI
#   vendor stays in read-only monitor mode.
#
# Note on shell options: the daemon deliberately does not use "set -e"; a
# transient ipmitool failure must not kill the control loop.

set -uo pipefail

readonly CONF=/etc/fanctl/fanctl.conf
readonly STATE_DIR=/var/lib/fanctl
readonly STATE_FILE="${STATE_DIR}/calibration.conf"

# --- Defaults (overridden by CONF) ------------------------------------------
IPMITOOL=ipmitool             # ipmitool binary; local IPMI via /dev/ipmi0.
ECTOOL=ectool                 # ectool binary; ChromeOS/Framework EC fan control.
POLL_INTERVAL=20              # Seconds between control cycles.
MIN_PCT=10                    # Fan speed floor, percent (baseline airflow).
MAX_PCT=100                   # Fan speed ceiling, percent.
# Per-component TARGET (optimal) and CRIT (hard safety) live in classify_sensor().
# The auto-calibrated fan curve tracks each component's TARGET in real time; that
# is the only control in normal operation. CRIT is a bare hard threshold
# (T >= crit -> 100%, NO margin) that only a program-level failure should ever
# reach -- it is a safety net, never an operating point.
# Compatibility fallback for a sensor whose label is NOT in the profile table but
# that declares a high critical of its own (typical of servers with generic sensor
# names like "Temp"): it is regulated toward GENERIC_TARGET with its own crit as
# the bypass, preserving the historical "any high-crit sensor is controlling"
# behaviour. Below GENERIC_CRIT_MIN an unclassified sensor is bypass-only.
GENERIC_TARGET=60             # Fallback target for an unclassified high-crit sensor.
GENERIC_DEADBAND=8            # Fallback anti-yoyo hysteresis for such a sensor.
GENERIC_RECAL=12             # Fallback recalibration threshold for such a sensor.
GENERIC_CRIT_MIN=80          # Min own-crit for an unclassified sensor to be controlling.
# Last-resort thermal escalation, in deg C ABOVE a component's survival crit
# (its Tjmax). Fans are already at 100% (knee bypass) well before this; these
# only fire if temperature keeps climbing past the hardware limit -- i.e. cooling
# has really failed. Keyed off SURVIVAL, never the longevity knee, so a normal
# load spike never powers off. Set any to a very high number to disable it.
CRIT_SURVIVE_NOTIFY=5         # +5 over survival  -> warn the user to save NOW.
CRIT_SURVIVE_SOFT=8           # +8 over survival  -> clean poweroff.
CRIT_SURVIVE_HARD=12          # +12 over survival -> violent instant power cut.
# Physical plausibility window for any temperature reading OR threshold, deg C.
# A value outside it comes from a stuck, unpopulated or parasitic sensor (a
# phantom 179C channel, a -273C unconnected one, a bogus 250C "critical") and
# must never drive control: taken as real it would either pin the fans to 100%
# forever or, as a bogus-high critical, mask a genuine over-temperature.
#
# The upper bound is the highest LEGITIMATE junction temperature any PC component
# reaches, all categories included, so a real hot part is never mistaken for a
# phantom (that would leave it uncooled): CPU Tjmax ~95-105C, GPU junction ~110C
# (AMD spec), NVMe controller ~120C, and the hottest of all -- VRM power MOSFETs,
# datasheet Tjmax 150C. So 150C is the market-wide legitimate ceiling; anything
# above can only be a phantom. Principle: when unsure, cool -- never cook.
TEMP_SANE_MIN=-40             # Below this a reading/threshold is discarded.
TEMP_SANE_MAX=150             # Above this a reading/threshold is discarded.
AMBIENT_MATCH='Inlet|Ambient' # Regex for the inlet-air sensor (excluded from control).
HYST_PCT=3                    # Minimum percent change before issuing a command.
TRIM_MAX=4                    # Max fan change per cycle while holding, percent.
INEFFECTIVE_MAX=3             # Fan rises with no cooling before easing back (anti-windup).
MAX_FAIL=3                    # Consecutive IPMI read errors before failsafe.
REQUIRE_KNOWN_VENDOR=0        # 1 = exit on unknown vendor; 0 = monitor mode.

# Calibration and drift tuning. (The deadband and the recalibration threshold are
# per component -- see classify_sensor; a hot-running part tolerates a wider swing
# than a slow one, which is what stops the fans from chasing every spike.)
STABLE_BAND=2     # Calibration: driver moving <= this over a window == stable.
DRIFT_CYCLES=5    # Cycles the error must stay past RECAL before recalibrating.
INLET_DRIFT=5     # Inlet change vs calibration that triggers recal, deg C.
STABILIZE_SECS=40 # Settle/measure window after a fan change while calibrating.
MAX_CAL_STEPS=10  # Maximum convergence steps per calibration.
CAL_STEP_MIN=2    # Minimum per-step fan change while calibrating, pct.
CAL_STEP_MAX=12   # Maximum per-step fan change while calibrating, pct.
DEFAULT_GAIN=3    # Fallback proportional gain, percent per deg C.

# shellcheck source=/dev/null
[[ -r "$CONF" ]] && . "$CONF"

# --- Runtime state ----------------------------------------------------------
BACKEND=none # Fan-control backend: ipmi | ec | hwmon | none.
# IPMI backend: detected vendor and its manual/auto raw commands.
IPMI_VENDOR=unknown
RAW_MANUAL=''
RAW_AUTO=''
# EC backend (ChromeOS/Framework embedded controller via ectool): fan count.
EC_NUMFANS=0
# hwmon backend: parallel arrays of controllable PWM channels.
HWMON_PWM=()     # Paths to writable pwmN files.
HWMON_EN=()      # Matching pwmN_enable paths.
HWMON_EN_ORIG=() # Their original enable values (restored on stop).
MODE=auto        # Current control mode: auto | manual.
LAST_PCT=-1      # Last applied speed, percent (-1 = unknown).
FAIL_COUNT=0     # Consecutive IPMI read failures.
DRIFT_COUNT=0    # Consecutive cycles with |error| >= the driver's RECAL.
REG_PREV_TEMP=-1 # Driver temperature at the previous cycle (anti-windup).
REG_PREV_PCT=-1  # Fan speed at the previous cycle (anti-windup).
REG_INEFFECTIVE=0 # Consecutive fan rises that did NOT cool the driver.

# Persisted calibration (loaded from STATE_FILE).
CAL_PCT=0   # Calibrated operating fan speed, percent.
CAL_SLOPE=0 # Measured response, deg C per percent (negative).
CAL_INLET=0 # Inlet temperature at calibration time, deg C.
CAL_FLOOR=0 # Calibrated constant floor: lowest speed that still holds stability.

# Metrics from the last read (set by eval of read_metrics).
CTRLTEMP=0     # Driving component temperature, deg C (furthest above its target).
CTRLTARGET=0   # That component's optimal target (from classify_sensor).
CTRLDEADBAND=0 # That component's anti-yoyo hysteresis (deg C).
CTRLRECAL=0    # That component's recalibration threshold (deg C).
CTRLLABEL=none # That component's sanitized name (for logs).
CRITHIT=0      # 1 = a component reached its own knee -> bare hard fan bypass.
CRITLABEL=none # The component that tripped the fan bypass (for logs).
SURVOVER=-1000 # Worst overshoot (deg C) above any component's survival crit.
SURVTEMP=0     # Temperature of that worst component, deg C.
SURVLABEL=none # Name of that worst component (for logs/notifications).
INLET=0        # Inlet-air temperature, deg C.
NCTRL=0        # Number of controlling components seen.
NOTIFY_SENT=0  # 1 = the "save now" warning is currently active (avoid spamming).
POWEROFF_INITIATED=0 # 1 = a poweroff has already been triggered this episode.

log() {
  printf '%s fanctl: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*"
}

#######################################
# Report whether a temperature value (deg C) is physically plausible, i.e. within
# [TEMP_SANE_MIN, TEMP_SANE_MAX]. Used to reject phantom/stuck sensor readings and
# bogus thresholds (from any exotic sensor, on any machine) before they can drive
# control. Generic and hardware-agnostic, like the rest of the program.
# Globals:
#   TEMP_SANE_MIN, TEMP_SANE_MAX (read)
# Arguments:
#   $1 - integer degrees C (may be negative)
# Returns:
#   0 if plausible, 1 otherwise (including a non-integer argument).
#######################################
temp_sane() {
  local t="$1"
  [[ "$t" =~ ^-?[0-9]+$ ]] || return 1
  ((t >= TEMP_SANE_MIN && t <= TEMP_SANE_MAX))
}

#######################################
# Classify a sensor into its component profile and emit
# "TARGET DEADBAND RECAL KNEE SURVIVAL" (all deg C, sourced, per class).
# TARGET   - optimal temperature the fan curve tracks in real time.
# DEADBAND - anti-yoyo hysteresis: the driver may sit this far from TARGET without
#            the fans moving at all. Wide for volatile parts (CPU/GPU), tight for
#            slow ones (HDD), so noisy spikes never chase the fans.
# RECAL    - error past which the curve is deemed wrong and recalibration runs.
# KNEE     - longevity knee; reaching it forces fans to 100% ("cool it now").
# SURVIVAL - hardware Tjmax; the last-resort poweroff escalation keys off THIS,
#            never the knee, so a normal load spike never powers the box off.
# Ambient/inlet is handled by the caller and never reaches here.
# Arguments:
#   $1 - lowercase "chipname label" classification key
# Outputs:
#   "TARGET DEADBAND RECAL KNEE SURVIVAL" to stdout.
# Returns:
#   0 if the sensor is a known component, 1 otherwise (caller decides).
#######################################
classify_sensor() {
  case "${1,,}" in
    *vram* | *gddr* | *amdgpu*mem* | *radeon*mem* | *nvidia*mem*) echo "60 6 10 95 100" ;;
    *amdgpu* | *radeon* | *nouveau* | *nvidia* | *gpu* | *junction* | *edge* | *hotspot*) echo "60 8 12 85 105" ;;
    *k10temp* | *coretemp* | *zenpower* | *package* | *tctl* | *tdie* | *tccd* | *core* | *cpu* | *apu* | *soc*) echo "60 10 15 80 95" ;;
    *vrm* | *mosfet* | *charger* | *vddgfx* | *vddnb*) echo "60 6 10 90 110" ;;
    *spd* | *dimm* | *memory* | *ram*) echo "50 5 8 85 95" ;;
    *pch* | *chipset*) echo "55 5 8 90 105" ;;
    *bat*) echo "30 4 7 45 60" ;;
    *nvme*) echo "60 5 8 80 90" ;;
    *ssd* | *sata* | *ahci* | *scsi*) echo "50 4 7 70 85" ;;
    *hdd* | *drivetemp*) echo "42 3 6 55 65" ;;
    *) return 1 ;;
  esac
}

#######################################
# Find writable hwmon PWM channels (standard PC fan control, no IPMI).
# Globals:
#   HWMON_PWM, HWMON_EN, HWMON_EN_ORIG (write)
# Returns:
#   0 if at least one controllable channel was found, 1 otherwise.
#######################################
detect_hwmon() {
  local pwm en
  for pwm in /sys/class/hwmon/hwmon*/pwm[0-9]*; do
    [[ "$pwm" =~ /pwm[0-9]+$ ]] || continue # skip pwmN_enable, pwmN_auto_*
    en="${pwm}_enable"
    [[ -w "$pwm" && -e "$en" ]] || continue
    HWMON_PWM+=("$pwm")
    HWMON_EN+=("$en")
    HWMON_EN_ORIG+=("$(cat "$en" 2>/dev/null || echo 2)")
  done
  [[ ${#HWMON_PWM[@]} -gt 0 ]]
}

#######################################
# Map an IPMI Manufacturer ID to a fan-control profile. Reading temperatures and
# fan tachometers over IPMI is standard across vendors; only the WRITE commands
# are OEM-specific, so this table is where brand support is added. Add a case to
# support a new vendor. Dell is verified on real hardware; other entries come
# from vendor documentation. The per-vendor speed encoding lives in fan_set.
# Globals:
#   IPMI_VENDOR, RAW_MANUAL, RAW_AUTO (write)
# Arguments:
#   $1 - Manufacturer ID (IANA number)
#######################################
ipmi_profile() {
  case "$1" in
    674) # Dell (iDRAC 7/8/9) — verified.
      IPMI_VENDOR=dell
      RAW_MANUAL='0x30 0x30 0x01 0x00'
      RAW_AUTO='0x30 0x30 0x01 0x01'
      ;;
    10876) # Supermicro (X9/X10/X11) — from documentation; zone-based speed.
      IPMI_VENDOR=supermicro
      RAW_MANUAL='0x30 0x45 0x01 0x01'
      RAW_AUTO='0x30 0x45 0x01 0x00'
      ;;
    *)
      IPMI_VENDOR=unknown
      ;;
  esac
}

#######################################
# Detect a ChromeOS/Framework embedded controller reachable through ectool.
# This is the fan-control path on laptops (e.g. Framework 16) that have no IPMI
# BMC and expose no writable hwmon PWM: the fans live behind the EC, and ectool
# is the only way to drive them. Reading temperatures still goes through hwmon
# (k10temp, amdgpu, ...); the EC backend only owns the fan WRITE path.
# Globals:
#   ECTOOL (read); EC_NUMFANS (write)
# Returns:
#   0 if the EC exposes at least one controllable fan, 1 otherwise.
#######################################
detect_ec() {
  command -v "$ECTOOL" >/dev/null 2>&1 || return 1
  local n
  n=$("$ECTOOL" pwmgetnumfans 2>/dev/null | grep -oE '[0-9]+' | head -1)
  [[ "$n" =~ ^[0-9]+$ && "$n" -gt 0 ]] || return 1
  EC_NUMFANS="$n"
  return 0
}

#######################################
# Select the fan-control backend, in order of specificity: a profiled IPMI BMC
# (servers, any brand), else a ChromeOS/Framework EC via ectool (laptops), else
# a writable hwmon PWM (standard PC). An IPMI BMC whose vendor is not profiled
# still allows read-only monitoring.
# Globals:
#   IPMITOOL, ECTOOL (read); BACKEND, IPMI_VENDOR, RAW_*, HWMON_*, EC_* (write)
#######################################
detect_backend() {
  local mc mfg
  mc=$("$IPMITOOL" mc info 2>/dev/null) || true
  mfg=$(awk -F: '/Manufacturer ID/ {gsub(/[^0-9]/, "", $2); print $2; exit}' \
    <<<"$mc")
  ipmi_profile "$mfg"
  if [[ -n "$RAW_MANUAL" ]]; then
    BACKEND=ipmi
    log "backend: ipmi/${IPMI_VENDOR} (Manufacturer ID=${mfg})"
    return
  fi
  if detect_ec; then
    BACKEND=ec
    log "backend: ec (ectool, ${EC_NUMFANS} fan(s))"
    return
  fi
  if detect_hwmon; then
    BACKEND=hwmon
    log "backend: hwmon (${#HWMON_PWM[@]} controllable PWM channel(s))"
    return
  fi
  BACKEND=none
  if [[ -n "$mfg" ]]; then
    log "backend: none (IPMI vendor ${mfg} not profiled; monitoring via IPMI)"
  else
    log "backend: none (no controllable fan interface; monitor only)"
  fi
}

can_control() {
  [[ "$BACKEND" != none ]]
}

fan_auto() {
  case "$BACKEND" in
    ipmi)
      # RAW_AUTO holds several space-separated hex bytes that must reach
      # ipmitool as separate arguments; the word-splitting is intentional.
      # shellcheck disable=SC2086
      "$IPMITOOL" raw $RAW_AUTO >/dev/null 2>&1
      ;;
    ec)
      # Hand every fan back to the EC's own automatic control.
      "$ECTOOL" autofanctrl >/dev/null 2>&1
      ;;
    hwmon)
      local i
      for i in "${!HWMON_EN[@]}"; do
        echo "${HWMON_EN_ORIG[$i]}" >"${HWMON_EN[$i]}" 2>/dev/null
      done
      ;;
    *) return 0 ;;
  esac
}

fan_manual() {
  case "$BACKEND" in
    ipmi)
      # RAW_MANUAL holds several space-separated hex bytes that must reach
      # ipmitool as separate arguments; the word-splitting is intentional.
      # shellcheck disable=SC2086
      "$IPMITOOL" raw $RAW_MANUAL >/dev/null 2>&1
      ;;
    hwmon)
      local en
      for en in "${HWMON_EN[@]}"; do echo 1 >"$en" 2>/dev/null; done
      ;;
    *) return 0 ;;
  esac
}

#######################################
# Set all fans to a given speed and remember it. The IPMI speed encoding is
# per-vendor (Dell: one command, all fans; Supermicro: one per fan zone).
# Globals:
#   BACKEND, IPMI_VENDOR, IPMITOOL, HWMON_PWM (read), LAST_PCT (write)
# Arguments:
#   $1 - speed as a decimal percent
# Returns:
#   0 on success, 1 on failure.
#######################################
fan_set() {
  case "$BACKEND" in
    ipmi)
      local hex
      hex=$(printf '0x%02x' "$1")
      case "$IPMI_VENDOR" in
        dell)
          "$IPMITOOL" raw 0x30 0x30 0x02 0xff "$hex" >/dev/null 2>&1 || return 1
          ;;
        supermicro)
          local z
          for z in 0x00 0x01; do
            "$IPMITOOL" raw 0x30 0x70 0x66 0x01 "$z" "$hex" >/dev/null 2>&1 \
              || return 1
          done
          ;;
        *) return 1 ;;
      esac
      ;;
    ec)
      # A single duty-cycle percent drives all EC fans; issuing it also switches
      # the EC out of automatic control, so no separate "manual" step is needed.
      "$ECTOOL" fanduty "$1" >/dev/null 2>&1 || return 1
      ;;
    hwmon)
      local pwmval p
      pwmval=$(($1 * 255 / 100))
      ((pwmval > 255)) && pwmval=255
      for p in "${HWMON_PWM[@]}"; do
        echo "$pwmval" >"$p" 2>/dev/null || return 1
      done
      ;;
    *) return 1 ;;
  esac
  LAST_PCT="$1"
  return 0
}

to_auto() {
  [[ "$MODE" == auto ]] && return 0
  if fan_auto; then
    MODE=auto
    LAST_PCT=-1
  fi
}

to_manual() {
  [[ "$MODE" == manual ]] && return 0
  fan_manual && MODE=manual
}

#######################################
# Apply a fan speed with hysteresis (clamped to [MIN_PCT, MAX_PCT]).
# Arguments:
#   $1 - desired percent
#######################################
apply_pct() {
  local pct="$1" delta
  ((pct < MIN_PCT)) && pct="$MIN_PCT"
  ((pct > MAX_PCT)) && pct="$MAX_PCT"
  to_manual
  delta=$((pct > LAST_PCT ? pct - LAST_PCT : LAST_PCT - pct))
  if ((LAST_PCT < 0 || delta >= HYST_PCT)); then
    if fan_set "$pct"; then
      log "fans -> ${pct}% (${CTRLLABEL} ${CTRLTEMP}C target=${CTRLTARGET}C)"
    else
      log "failed to set fan speed -> automatic fan control"
      to_auto
    fi
  fi
}

#######################################
# Read metrics via IPMI in a single ipmitool pass, classifying each sensor into
# its component profile (same table as classify_sensor).
# Globals:
#   IPMITOOL, AMBIENT_MATCH, TEMP_SANE_* (read)
# Outputs:
#   "CTRLTEMP=.. CTRLTARGET=.. CTRLLABEL=.. CRITHIT=.. CRITLABEL=.. INLET=.. NCTRL=.."
# Returns:
#   0 on success, 1 if IPMI returned nothing.
#######################################
read_metrics_ipmi() {
  local out
  out=$("$IPMITOOL" sensor 2>/dev/null) || return 1
  [[ -n "$out" ]] || return 1
  awk -F'|' -v amb="$AMBIENT_MATCH" \
    -v tmin="$TEMP_SANE_MIN" -v tmax="$TEMP_SANE_MAX" \
    -v gtarget="$GENERIC_TARGET" -v gcritmin="$GENERIC_CRIT_MIN" \
    -v gdband="$GENERIC_DEADBAND" -v grecal="$GENERIC_RECAL" '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
    function sane(v) { return (v >= tmin && v <= tmax) }
    # Same sourced profiles as classify_sensor(); sets g_t/g_c/g_s (target, knee,
    # survival), returns 1 if the sensor name is a known component class.
    function classify(n,   l) {
      l = tolower(n)
      if (l ~ /vram|gddr/)                                   { g_t=60; g_d=6;  g_r=10; g_c=95; g_s=100; return 1 }
      if (l ~ /gpu|junction|edge|hotspot/)                   { g_t=60; g_d=8;  g_r=12; g_c=85; g_s=105; return 1 }
      if (l ~ /cpu|package|tctl|tdie|tccd|core|apu|soc|proc/){ g_t=60; g_d=10; g_r=15; g_c=80; g_s=95;  return 1 }
      if (l ~ /vrm|mosfet|charger|vcore|vddgfx/)             { g_t=60; g_d=6;  g_r=10; g_c=90; g_s=110; return 1 }
      if (l ~ /dimm|memory|ram|spd/)                         { g_t=50; g_d=5;  g_r=8;  g_c=85; g_s=95;  return 1 }
      if (l ~ /pch|chipset/)                                 { g_t=55; g_d=5;  g_r=8;  g_c=90; g_s=105; return 1 }
      if (l ~ /bat/)                                         { g_t=30; g_d=4;  g_r=7;  g_c=45; g_s=60;  return 1 }
      if (l ~ /nvme/)                                        { g_t=60; g_d=5;  g_r=8;  g_c=80; g_s=90;  return 1 }
      if (l ~ /ssd|sata|ahci|scsi/)                          { g_t=50; g_d=4;  g_r=7;  g_c=70; g_s=85;  return 1 }
      if (l ~ /hdd|drive/)                                   { g_t=42; g_d=3;  g_r=6;  g_c=55; g_s=65;  return 1 }
      return 0
    }
    BEGIN { best = -1000; survover = -1000 }
    { name = trim($1); reading = trim($2); unit = trim($3); ucr = trim($9) }
    unit ~ /degrees C/ && reading ~ /^[0-9]+(\.[0-9]+)?$/ {
      r = reading + 0
      if (!sane(r)) next
      if (name ~ amb) { inlet = r; next }
      sc = (ucr ~ /^[0-9]+(\.[0-9]+)?$/ && sane(ucr + 0)) ? ucr + 0 : 0
      if (classify(name)) {
        if (sc > 0 && sc < g_c) g_c = sc   # tighter real crit wins the fan bypass
        if (sc > 0) g_s = sc               # real Tjmax drives the poweroff escalation
      } else if (sc >= gcritmin) {
        g_t = gtarget; g_d = gdband; g_r = grecal; g_c = sc; g_s = sc  # generic sensor
      } else {
        if (sc > 0 && r >= sc) { crithit = 1; crlabel = name }  # low-crit: bypass only
        next
      }
      nctrl++
      press = r - g_t
      if (press > best) { best = press; ctemp = r; ctarget = g_t; cdband = g_d; crecal = g_r; clabel = name }
      if (r >= g_c) { crithit = 1; crlabel = name }   # bare hard fan threshold
      over = r - g_s
      if (over > survover) { survover = over; survtemp = r; survlabel = name }
    }
    END {
      gsub(/[^A-Za-z0-9_-]/, "_", clabel); gsub(/[^A-Za-z0-9_-]/, "_", crlabel)
      gsub(/[^A-Za-z0-9_-]/, "_", survlabel)
      if (clabel == "") clabel = "none"
      if (crlabel == "") crlabel = "none"
      if (survlabel == "") survlabel = "none"
      printf "CTRLTEMP=%d CTRLTARGET=%d CTRLDEADBAND=%d CTRLRECAL=%d CTRLLABEL=%s CRITHIT=%d CRITLABEL=%s SURVOVER=%d SURVTEMP=%d SURVLABEL=%s INLET=%d NCTRL=%d\n", \
        int(ctemp + 0.5), ctarget + 0, cdband + 0, crecal + 0, clabel, crithit + 0, crlabel, \
        (survover == -1000 ? -1000 : int(survover + 0.5)), int(survtemp + 0.5), survlabel, \
        int(inlet + 0.5), nctrl + 0
    }' <<<"$out"
}

#######################################
# Read metrics from Linux hwmon sensors (coretemp, k10temp, amdgpu, nvme, ...).
# Each sensor is classified into its component profile (target + crit). The
# driver of regulation is the component furthest above ITS OWN target; the bypass
# fires as soon as any component reaches ITS OWN crit (bare, no margin). A sensor
# with an unknown class but a real sysfs crit still counts for the bypass only.
# Globals:
#   AMBIENT_MATCH (read)
# Outputs:
#   "CTRLTEMP=.. CTRLTARGET=.. CTRLLABEL=.. CRITHIT=.. CRITLABEL=.. INLET=.. NCTRL=.."
# Returns:
#   0 if any temperature was read, 1 otherwise.
#######################################
read_metrics_hwmon() {
  local ti base val label chip key crit ccrit prof tgt dband recal surv tdeg press over
  local inlet=0 nctrl=0 any=0
  local best=-1000 ctemp=0 ctarget=0 cdband=0 crecal=0 clabel=none crithit=0 crlabel=none
  local survover=-1000 survtemp=0 survlabel=none
  for ti in /sys/class/hwmon/hwmon*/temp[0-9]*_input; do
    [[ -r "$ti" ]] || continue
    val=$(cat "$ti" 2>/dev/null)
    [[ "$val" =~ ^[0-9]+$ ]] || continue
    tdeg=$((val / 1000))
    # Reject a phantom/stuck reading before it can drive control (a 179C ghost).
    temp_sane "$tdeg" || continue
    any=1
    base="${ti%_input}"
    label=$(cat "${base}_label" 2>/dev/null || echo "")
    chip=$(cat "${base%/*}/name" 2>/dev/null || echo "")
    key="${chip} ${label}"
    # Ambient/inlet is a reference, never a controlling component.
    [[ "$key" =~ $AMBIENT_MATCH ]] && {
      inlet=$tdeg
      continue
    }
    # This sensor's own sysfs critical, if plausible.
    crit=$(cat "${base}_crit" 2>/dev/null || echo "")
    if [[ "$crit" =~ ^[0-9]+$ ]]; then ccrit=$((crit / 1000)); else ccrit=0; fi
    temp_sane "$ccrit" || ccrit=0
    if prof=$(classify_sensor "$key"); then
      # Known component. KNEE = min(sourced, sysfs) so a tighter real threshold
      # wins the fan bypass; SURVIVAL = the real sysfs Tjmax if present, else the
      # sourced market Tjmax -- this is what the poweroff escalation keys off.
      read -r tgt dband recal crit surv <<<"$prof"
      ((ccrit > 0 && ccrit < crit)) && crit="$ccrit"
      ((ccrit > 0)) && surv="$ccrit"
    elif ((ccrit >= GENERIC_CRIT_MIN)); then
      # Unclassified but a high own-crit: a hot active component (generic server
      # sensor). Regulate toward the generic target; its own crit is both the fan
      # bypass and the survival threshold.
      tgt="$GENERIC_TARGET"
      dband="$GENERIC_DEADBAND"
      recal="$GENERIC_RECAL"
      crit="$ccrit"
      surv="$ccrit"
    elif ((ccrit > 0)); then
      # Unclassified low-crit sensor: fan bypass only. No poweroff escalation --
      # a low, unqualified crit must never be able to power the machine off.
      ((tdeg >= ccrit)) && {
        crithit=1
        crlabel=${key//[^A-Za-z0-9_-]/_}
      }
      continue
    else
      continue # Nothing usable (no class, no crit).
    fi
    # Regulated component: drive the curve, arm the fan bypass, and track the
    # worst overshoot above SURVIVAL for the last-resort poweroff escalation.
    ((nctrl++))
    press=$((tdeg - tgt))
    if ((press > best)); then
      best=$press
      ctemp=$tdeg
      ctarget=$tgt
      cdband=$dband
      crecal=$recal
      clabel=${key//[^A-Za-z0-9_-]/_}
    fi
    ((tdeg >= crit)) && {
      crithit=1
      crlabel=${key//[^A-Za-z0-9_-]/_}
    }
    over=$((tdeg - surv))
    if ((over > survover)); then
      survover=$over
      survtemp=$tdeg
      survlabel=${key//[^A-Za-z0-9_-]/_}
    fi
  done
  ((any == 0)) && return 1
  printf "CTRLTEMP=%d CTRLTARGET=%d CTRLDEADBAND=%d CTRLRECAL=%d CTRLLABEL=%s CRITHIT=%d CRITLABEL=%s SURVOVER=%d SURVTEMP=%d SURVLABEL=%s INLET=%d NCTRL=%d\n" \
    "$ctemp" "$ctarget" "$cdband" "$crecal" "$clabel" "$crithit" "$crlabel" "$survover" "$survtemp" "$survlabel" "$inlet" "$nctrl"
}

#######################################
# Read metrics through whichever source fits the active backend.
# Falls back to trying both in monitor mode so temperatures can still be logged.
# Globals:
#   BACKEND, IPMITOOL (read)
#######################################
read_metrics() {
  case "$BACKEND" in
    ipmi) read_metrics_ipmi ;;
    ec) read_metrics_hwmon ;;
    hwmon) read_metrics_hwmon ;;
    *) read_metrics_ipmi || read_metrics_hwmon ;;
  esac
}

#######################################
# Proportional gain (percent per deg C) from the calibrated slope.
# Globals:
#   CAL_SLOPE, DEFAULT_GAIN (read)
# Outputs:
#   The gain to stdout.
#######################################
current_gain() {
  # CAL_SLOPE is deg C per percent (negative); gain is its inverse magnitude.
  awk -v s="$CAL_SLOPE" -v d="$DEFAULT_GAIN" 'BEGIN {
    a = (s < 0) ? -s : s
    if (a < 0.05) { print d; exit }
    g = 1.0 / a
    if (g < 1) g = 1
    if (g > 10) g = 10
    printf "%d", g + 0.5
  }'
}

load_calibration() {
  if [[ -r "$STATE_FILE" ]]; then
    # shellcheck source=/dev/null
    . "$STATE_FILE"
    log "loaded calibration:" \
      "pct=${CAL_PCT}% floor=${CAL_FLOOR}% slope=${CAL_SLOPE}C/% inlet=${CAL_INLET}C"
    return 0
  fi
  return 1
}

save_calibration() {
  mkdir -p "$STATE_DIR"
  cat >"$STATE_FILE" <<EOF
# Written by fanctl --calibrate. Do not edit by hand.
CAL_PCT=${CAL_PCT}
CAL_FLOOR=${CAL_FLOOR}
CAL_SLOPE=${CAL_SLOPE}
CAL_INLET=${CAL_INLET}
CAL_TARGET=${CTRLTARGET}
CAL_TS=$(date '+%Y-%m-%dT%H:%M:%S%z')
EOF
}

#######################################
# Measure the quiet operating point for the current conditions and persist it.
# Converges the fan speed so the hottest sensor sits near the target, and
# derives the fan/temperature slope from the last two convergence points.
# Globals:
#   Calibration tuning and CAL_* state.
#######################################
calibrate() {
  can_control || return 0
  read_metrics_into || return 1
  log "calibrating: driver=${CTRLLABEL} target=${CTRLTARGET}C" \
    "(inlet=${INLET}C, ${NCTRL} components)..."
  to_manual

  local pct prev_pct=-1 prev_t=-1 step err t0 trend cal_ineffective=0 cal_prev_t=-1
  # Start from the current fan speed if known (a post-critical recalibration thus
  # begins at 100% and only eases down), else the last calibrated point, else mid.
  if ((LAST_PCT >= 0)); then
    pct="$LAST_PCT"
  elif ((CAL_PCT > 0)); then
    pct="$CAL_PCT"
  else
    pct=$(((MIN_PCT + MAX_PCT) / 2))
  fi
  # Search for the LOWEST speed that still holds the driver stable at/below its
  # target -- the constant idle floor -- instead of validating whatever speed we
  # started from. While a speed holds, step DOWN to probe lower; the moment a
  # speed no longer holds, the last holding one just above was the minimum.
  local i floor=-1
  for ((i = 0; i < MAX_CAL_STEPS; i++)); do
    ((pct < MIN_PCT)) && pct="$MIN_PCT"
    ((pct > MAX_PCT)) && pct="$MAX_PCT"
    fan_set "$pct"
    # Measure the TREND over the settle window (dT/dt), not a single instant: read
    # the driver at the start and end and see whether it rises, falls or holds.
    read_metrics_into || return 1
    t0=$CTRLTEMP
    sleep "$STABILIZE_SECS"
    read_metrics_into || return 1
    trend=$((CTRLTEMP - t0))
    err=$((CTRLTEMP - CTRLTARGET))
    log "  step ${i}: ${pct}% -> ${CTRLLABEL} ${CTRLTEMP}C trend=${trend}C/win err=${err}C"

    # Slope (deg C per percent) from two distinct operating points, for the gain.
    if ((prev_pct >= 0 && pct != prev_pct)); then
      CAL_SLOPE=$(awk \
        -v t1="$prev_t" -v t2="$CTRLTEMP" -v p1="$prev_pct" -v p2="$pct" \
        'BEGIN { printf "%.3f", (t2 - t1) / (p2 - p1) }')
    fi
    prev_pct="$pct"
    prev_t="$CTRLTEMP"

    if ((trend <= STABLE_BAND && err <= CTRLDEADBAND)); then
      # HOLDS: stable and at/below target. Record it and probe lower.
      floor="$pct"
      ((pct <= MIN_PCT)) && break
      ((pct -= CAL_STEP_MAX))
    else
      # Does NOT hold (rising or above target): needs more air.
      ((floor >= 0)) && break     # the minimum was the last holding step just above
      if ((pct >= MAX_PCT)); then
        # At full speed but STILL not holding. If even MAX is not cooling it
        # (trend not clearly falling), the fans have no grip -> the floor is MIN,
        # NOT max (blasting full does nothing). Never persist a bogus 100% floor.
        # Only keep MAX when MAX genuinely helps (trend falling).
        ((trend > -STABLE_BAND)) && floor="$MIN_PCT"
        break
      fi
      # Anti-windup: if raising the fans is NOT cooling the driver, more air is
      # useless (fans have no grip on it) -- stop before ramping to MAX and settle
      # at the minimum, exactly like the live loop. The driver stays fully watched.
      if ((cal_prev_t >= 0 && CTRLTEMP >= cal_prev_t)); then
        ((cal_ineffective++))
      else
        cal_ineffective=0
      fi
      cal_prev_t="$CTRLTEMP"
      ((cal_ineffective >= INEFFECTIVE_MAX)) && {
        floor="$MIN_PCT"
        break
      }
      if ((trend > STABLE_BAND)); then
        ((pct += CAL_STEP_MAX))
      else
        step=$((err))
        ((step < CAL_STEP_MIN)) && step="$CAL_STEP_MIN"
        ((step > CAL_STEP_MAX)) && step="$CAL_STEP_MAX"
        ((pct += step))
      fi
    fi
  done

  # The floor IS the operating point at calibration time; under load the live loop
  # raises the speed above it. Never below MIN_PCT.
  ((floor < 0)) && floor="$pct"
  ((floor < MIN_PCT)) && floor="$MIN_PCT"
  CAL_PCT="$floor"
  CAL_FLOOR="$floor"
  CAL_INLET="$INLET"
  save_calibration
  DRIFT_COUNT=0
  log "calibrated: pct=${CAL_PCT}% floor=${CAL_FLOOR}%" \
    "slope=${CAL_SLOPE}C/% (gain=$(current_gain)%/C)"
}

# read_metrics wrapper that assigns the CTRL*/CRIT*/INLET/NCTRL globals. All
# emitted values are numeric or sanitized names, so eval is safe.
read_metrics_into() {
  local line
  line=$(read_metrics) || return 1
  # shellcheck disable=SC2086
  eval "$line"
  return 0
}

cleanup() {
  log "stopping -> restoring automatic fan control"
  can_control && fan_auto
}

do_check() {
  detect_backend
  echo "--- Temperature sensors ---"
  if [[ "$BACKEND" == hwmon || "$BACKEND" == ec ]]; then
    local ti b val crit
    for ti in /sys/class/hwmon/hwmon*/temp[0-9]*_input; do
      [[ -r "$ti" ]] || continue
      b="${ti%_input}"
      # A present-but-unreadable sensor (e.g. an unconnected channel) returns no
      # data; skip it so we never divide an empty string.
      val=$(cat "$ti" 2>/dev/null)
      [[ "$val" =~ ^[0-9]+$ ]] || continue
      crit=$(cat "${b}_crit" 2>/dev/null)
      [[ "$crit" =~ ^[0-9]+$ ]] || crit=0
      printf "  %-24s reading=%sC crit=%sC\n" \
        "$(cat "${b}_label" 2>/dev/null || basename "$b")" \
        "$((val / 1000))" "$((crit / 1000))"
    done
  else
    "$IPMITOOL" sensor 2>/dev/null | awk -F'|' '
      function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
      { u = trim($3) }
      u ~ /degrees C/ {
        printf "  %-22s reading=%-8s upper-crit=%s\n", \
          trim($1), trim($2), trim($9)
      }'
  fi
  echo "--- Fans ---"
  if [[ "$BACKEND" == ec ]]; then
    "$ECTOOL" pwmgetfanrpm all 2>/dev/null | sed 's/^/  /'
  elif [[ "$BACKEND" == hwmon ]]; then
    local f
    for f in /sys/class/hwmon/hwmon*/fan[0-9]*_input; do
      [[ -r "$f" ]] && printf "  %s: %s RPM\n" \
        "$(basename "$(dirname "$f")")/$(basename "${f%_input}")" "$(cat "$f")"
    done
  else
    "$IPMITOOL" sdr type fan 2>/dev/null | sed 's/^/  /'
  fi
  echo "--- Metrics ---"
  if read_metrics_into; then
    echo "  driver=${CTRLLABEL} ${CTRLTEMP}C (target ${CTRLTARGET}C," \
      "deadzone +/-${CTRLDEADBAND}C, recal ${CTRLRECAL}C)" \
      "fan-bypass=${CRITHIT} floor=${CAL_FLOOR}% components=${NCTRL} inlet=${INLET}C"
    echo "  closest to survival: ${SURVLABEL} ${SURVTEMP}C (${SURVOVER}C vs Tjmax;" \
      "notify/soft/hard at +${CRIT_SURVIVE_NOTIFY}/+${CRIT_SURVIVE_SOFT}/+${CRIT_SURVIVE_HARD})"
  else
    echo "  (no readable sensors)"
  fi
  echo "--- Calibration ---"
  if load_calibration; then :; else echo "  (not calibrated yet)"; fi
  echo "--- Active control available? ---"
  if can_control; then echo "  yes (backend=${BACKEND})"; else
    echo "  no -> monitor mode (backend=${BACKEND})"
  fi
}

do_restore() {
  detect_backend
  if can_control; then
    fan_auto && log "regulation handed back (automatic)"
  else
    log "nothing to restore (backend=${BACKEND})"
  fi
}

#######################################
# Warn every logged-in user that a component is over its survival limit and the
# machine is about to power off. wall + journal are guaranteed; desktop toasts
# are opportunistic (best-effort per active graphical session).
# Arguments:
#   $1 - message text
#######################################
notify_user() {
  local msg="$1"
  logger -t fanctl -p daemon.crit "$msg" 2>/dev/null
  wall "fanctl: $msg" 2>/dev/null
  local bus uid user
  for bus in /run/user/*/bus; do
    [[ -S "$bus" ]] || continue
    uid=${bus#/run/user/}
    uid=${uid%/bus}
    user=$(id -nu "$uid" 2>/dev/null) || continue
    runuser -u "$user" -- env DBUS_SESSION_BUS_ADDRESS="unix:path=${bus}" \
      notify-send -u critical "fanctl — OVERHEAT" "$msg" 2>/dev/null || true
  done
}

#######################################
# Clean, orderly poweroff (a component passed survival + CRIT_SURVIVE_SOFT).
# Globals:
#   SURVLABEL, SURVTEMP, SURVOVER (read)
#######################################
soft_poweroff() {
  log "SOFT POWEROFF: ${SURVLABEL} ${SURVTEMP}C," \
    "+${SURVOVER}C over its survival crit -> clean shutdown"
  notify_user "OVERHEAT ${SURVLABEL} ${SURVTEMP}C -- powering off cleanly NOW"
  systemctl poweroff 2>/dev/null || shutdown -h now 2>/dev/null \
    || poweroff 2>/dev/null || true
}

#######################################
# Violent instant power cut (a component passed survival + CRIT_SURVIVE_HARD): no
# sync, no shutdown sequence. SysRq 'o' cuts power immediately, like holding the
# power button -- the last resort before the hardware thermal trip.
# Globals:
#   SURVLABEL, SURVTEMP, SURVOVER (read)
#######################################
hard_poweroff() {
  log "HARD POWEROFF: ${SURVLABEL} ${SURVTEMP}C," \
    "+${SURVOVER}C over its survival crit -> INSTANT power cut"
  echo 1 >/proc/sys/kernel/sysrq 2>/dev/null || true
  echo o >/proc/sysrq-trigger 2>/dev/null
  systemctl --force --force poweroff 2>/dev/null || poweroff -f 2>/dev/null || true
}

#######################################
# One regulation cycle: hard-safety bypass and poweroff escalation, then a dead
# zone (anti-yoyo) around the driver's target, else a bounded nudge toward it
# floored at CAL_FLOOR, plus per-component recal and crit-driven recalibration.
# Globals:
#   CTRLTEMP, CTRLTARGET, CTRLDEADBAND, CTRLRECAL, CRITHIT, CRITLABEL, SURVOVER,
#   SURVTEMP, SURVLABEL, INLET, CAL_PCT, CAL_FLOOR, CAL_INLET, DRIFT_COUNT,
#   NOTIFY_SENT, POWEROFF_INITIATED and tuning.
#######################################
regulate() {
  local err gain step pct base inlet_delta

  # Reset the one-shot warning latch once back below the warn threshold.
  ((SURVOVER < CRIT_SURVIVE_NOTIFY)) && NOTIFY_SENT=0

  # Hard fan bypass (bare, no margin): a component reached ITS OWN knee. This must
  # never happen in normal use -- the real-time curve holds every component at its
  # target -- so a repeated trip means the calibration is off.
  if ((CRITHIT == 1)); then
    apply_pct "$MAX_PCT"
    log "CRITICAL bypass: ${CRITLABEL} reached its knee -> max cooling"

    # Last-resort thermal escalation, keyed off SURVIVAL (Tjmax), NOT the knee, so
    # a normal load spike never powers off. Fans are already at 100%; these only
    # fire if temperature keeps climbing past the hardware limit. Most-severe first.
    if ((SURVOVER >= CRIT_SURVIVE_HARD)); then
      hard_poweroff # violent, does not return
    elif ((SURVOVER >= CRIT_SURVIVE_SOFT)); then
      ((POWEROFF_INITIATED == 0)) && {
        POWEROFF_INITIATED=1
        soft_poweroff
      }
      return
    elif ((SURVOVER >= CRIT_SURVIVE_NOTIFY)); then
      ((NOTIFY_SENT == 0)) && {
        NOTIFY_SENT=1
        notify_user "OVERHEAT ${SURVLABEL} ${SURVTEMP}C -- SAVE NOW, imminent poweroff"
      }
    fi

    # Reaching the knee is proof the curve is wrong, so recalibrate immediately
    # (cumulative with the target-drift check below). Calibration restarts from
    # the current 100%, so it never eases off while a component is critical.
    calibrate
    return
  fi

  # Error of the driving component against its own optimal target.
  err=$((CTRLTEMP - CTRLTARGET))
  local abs_err=$((err < 0 ? -err : err))

  # Anti-windup accounting FIRST (before recalibration): did last cycle's fan RISE
  # actually cool the driver? If we raised the speed and the temperature did NOT
  # drop, the fans have no grip on this component. Kept ahead of recalibration so a
  # component the fans cannot cool is recognised as such and never triggers one.
  if ((REG_PREV_PCT >= 0 && LAST_PCT > REG_PREV_PCT && CTRLTEMP >= REG_PREV_TEMP)); then
    ((REG_INEFFECTIVE++))
  elif ((REG_PREV_TEMP >= 0 && CTRLTEMP < REG_PREV_TEMP)); then
    REG_INEFFECTIVE=0 # it cooled -> the fans do have grip, keep them honest
  fi
  REG_PREV_TEMP=$CTRLTEMP
  REG_PREV_PCT=$LAST_PCT

  # Recalibration: the error stayed past the driver's RECAL band -> the curve is
  # wrong (cooling too much or too little). Persist a few cycles so a transient
  # spike does not trigger it. Also on an inlet-air shift. But NOT when the fans
  # have no grip on the driver (REG_INEFFECTIVE maxed): recalibrating a component
  # the fans cannot cool is sterile -- it re-measures the same floor and loops.
  inlet_delta=$((INLET > CAL_INLET ? INLET - CAL_INLET : CAL_INLET - INLET))
  if ((abs_err >= CTRLRECAL && REG_INEFFECTIVE < INEFFECTIVE_MAX)); then
    ((DRIFT_COUNT++))
  else
    DRIFT_COUNT=0
  fi
  if ((DRIFT_COUNT >= DRIFT_CYCLES)); then
    log "sustained drift (${CTRLLABEL} err=${err}C >= recal ${CTRLRECAL}C) -> recalibrate"
    DRIFT_COUNT=0
    calibrate
    return
  fi
  if ((inlet_delta > INLET_DRIFT && REG_INEFFECTIVE < INEFFECTIVE_MAX)); then
    log "inlet shifted (${CAL_INLET}C -> ${INLET}C) -> recalibrate"
    calibrate
    return
  fi

  # Anti-yoyo dead zone: within the driver's DEADBAND of its target, hold the fans
  # perfectly steady and ignore the noise. This is what kills the oscillation.
  ((abs_err < CTRLDEADBAND)) && {
    REG_INEFFECTIVE=0
    return
  }

  # Between DEADBAND and RECAL: nudge the speed toward the target by a bounded
  # step (gain from the calibrated slope). Never fall below the calibrated
  # constant floor, so the machine idles at one steady speed instead of yoyo-ing.
  gain=$(current_gain)
  step=$((err * gain))
  ((step > TRIM_MAX)) && step="$TRIM_MAX"
  ((step < -TRIM_MAX)) && step=$((-TRIM_MAX))
  ((step == 0)) && step=$((err > 0 ? 1 : -1))
  # Anti-windup: raising is proven useless on this driver -> stop wasting airflow
  # and ease back to the floor. The component stays fully watched -- its knee still
  # trips the 100% bypass and survival still escalates if it ever really overheats.
  if ((step > 0 && REG_INEFFECTIVE >= INEFFECTIVE_MAX)); then
    step=$((-TRIM_MAX))
  fi
  base=$((LAST_PCT >= 0 ? LAST_PCT : CAL_PCT))
  pct=$((base + step))
  ((CAL_FLOOR > 0 && pct < CAL_FLOOR)) && pct="$CAL_FLOOR"
  apply_pct "$pct"
}

run_daemon() {
  detect_backend
  if ! can_control; then
    log "no controllable fan backend."
    if [[ "$REQUIRE_KNOWN_VENDOR" == 1 ]]; then
      log "REQUIRE_KNOWN_VENDOR=1 -> exiting"
      exit 0
    fi
    log "monitor mode: read-only, fans left to automatic control."
  fi
  trap cleanup EXIT
  trap 'exit 0' INT TERM
  log "starting (poll=${POLL_INTERVAL}s per-component targets" \
    "range=${MIN_PCT}-${MAX_PCT}%)"

  if can_control; then
    to_manual
    load_calibration || calibrate
  fi

  while :; do
    if ! read_metrics_into; then
      FAIL_COUNT=$((FAIL_COUNT + 1))
      log "IPMI read failed (${FAIL_COUNT}/${MAX_FAIL})"
      ((FAIL_COUNT >= MAX_FAIL)) && can_control && to_auto
      sleep "$POLL_INTERVAL"
      continue
    fi
    FAIL_COUNT=0

    if ! can_control; then
      log "monitor: ${CTRLLABEL} ${CTRLTEMP}C inlet=${INLET}C components=${NCTRL}"
      sleep "$POLL_INTERVAL"
      continue
    fi
    if ((NCTRL == 0)); then
      log "no controlling sensor readable -> automatic fan control (safety)"
      to_auto
      sleep "$POLL_INTERVAL"
      continue
    fi

    regulate
    sleep "$POLL_INTERVAL"
  done
}

main() {
  case "${1:---daemon}" in
    --check) do_check ;;
    --restore) do_restore ;;
    --calibrate)
      detect_backend
      to_manual
      load_calibration || true
      calibrate
      cleanup
      ;;
    --once)
      detect_backend
      read_metrics
      ;;
    --daemon) run_daemon ;;
    *)
      echo "usage: fanctl [--daemon|--check|--calibrate|--restore|--once]" >&2
      exit 2
      ;;
  esac
}

main "$@"
