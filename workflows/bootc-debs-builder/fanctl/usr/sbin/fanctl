#!/bin/bash
#
# fanctl — generic temperature-driven fan controller over local IPMI
#
# Usage: fanctl [--daemon|--check|--dry-run|--restore|--once]
#   --daemon   Run the control loop (default when no argument is given).
#   --check    Print discovered sensors, fans, vendor and computed state.
#   --dry-run  Run the control loop but never write to the BMC.
#   --restore  Hand fan regulation back to the BMC (automatic) and exit.
#   --once     Print one raw state line and exit.
#
# How it works:
#   Temperature sensors and their own Upper-Critical thresholds are discovered
#   at runtime from ipmitool, so no threshold is hard-coded and the same speed
#   curve self-scales to any CPU. Sensors whose Upper-Critical is high enough
#   (CONTROL_UCR_MIN) are treated as the controlling (CPU-class) sensors.
#
#   Writing the fan speed is the only vendor-specific step. The vendor is
#   auto-detected via "ipmitool mc info" (IANA Manufacturer ID) and mapped to a
#   small command profile. Dell iDRAC is supported; any unknown vendor falls
#   back to monitor mode and never touches the fans.
#
#   The BMC automatic regulation is restored on any failsafe: over-temperature,
#   a failed fan, unreadable sensors, repeated IPMI errors, or process exit.
#
# Note on shell options: the daemon deliberately does not use "set -e". A
# transient ipmitool failure must not kill the control loop; every command that
# may fail is handled explicitly and falls back to safe BMC regulation.

set -uo pipefail

readonly CONF=/etc/fanctl/fanctl.conf

# --- Defaults (overridden by CONF) ------------------------------------------
# These are plain (non-readonly) variables because the config file reassigns
# them when present.
IPMITOOL=ipmitool         # ipmitool binary; local IPMI via /dev/ipmi0
POLL_INTERVAL=15          # Seconds between regulation cycles.
MIN_PCT=20                # Fan speed floor, percent.
MAX_PCT=100               # Fan speed ceiling, percent.
BASE_TEMP=35              # Idle temperature, degrees C (bottom of the curve).
SAFETY_MARGIN=15          # Curve top = sensor Upper-Critical minus this (deg C).
HARD_MARGIN=8             # Failsafe to BMC at Upper-Critical minus this (deg C).
HYST_PCT=4                # Minimum percent change before issuing a command.
CONTROL_UCR_MIN=80        # A sensor with Upper-Critical >= this is CPU-class.
AMBIENT_MATCH='Inlet|Ambient'  # Regex for the inlet-air sensor (extra guard).
ALLOW_DEGRADED=0          # 1 = keep regulating with a failed fan (raised floor).
DEGRADED_MIN_PCT=40       # Fan speed floor while degraded, percent.
MAX_FAIL=3                # Consecutive IPMI read errors before failsafe.
REQUIRE_KNOWN_VENDOR=0    # 1 = exit on unknown vendor; 0 = monitor mode.

# shellcheck source=/dev/null
[[ -r "$CONF" ]] && . "$CONF"

# --- Runtime state ----------------------------------------------------------
VENDOR=unknown            # Detected vendor key.
RAW_MANUAL=''             # Raw command args: switch to manual fan control.
RAW_AUTO=''               # Raw command args: switch back to BMC automatic.
RAW_SET_PREFIX=''         # Raw command prefix: set speed (speed byte appended).
DRY_RUN=0                 # 1 = never write to the BMC.
MODE=auto                 # Current control mode: auto | manual.
LAST_PCT=-1               # Last applied speed, percent (-1 = unknown).
FAIL_COUNT=0              # Consecutive IPMI read failures.
FAN_FAIL_LOGGED=0         # Whether the current fan failure was already logged.

#######################################
# Write a timestamped line to stdout.
# Arguments:
#   $* - message
# Outputs:
#   Writes the message to stdout.
#######################################
log() {
  printf '%s fanctl: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*"
}

#######################################
# Detect the BMC vendor and populate the raw command profile.
# Globals:
#   IPMITOOL (read), VENDOR, RAW_MANUAL, RAW_AUTO, RAW_SET_PREFIX (write)
# Outputs:
#   Logs the detected vendor.
#######################################
detect_vendor() {
  local mc mfg
  mc=$("$IPMITOOL" mc info 2>/dev/null) || true
  mfg=$(awk -F: '/Manufacturer ID/ {gsub(/[^0-9]/, "", $2); print $2; exit}' \
    <<<"$mc")
  case "$mfg" in
    674)  # Dell (iDRAC 7/8/9): the 0x30 0x30 OEM command family.
      VENDOR=dell
      RAW_MANUAL='0x30 0x30 0x01 0x00'
      RAW_AUTO='0x30 0x30 0x01 0x01'
      RAW_SET_PREFIX='0x30 0x30 0x02 0xff'  # Append speed byte (hex percent).
      ;;
    *)
      VENDOR=unknown
      ;;
  esac
  log "vendor detected: ${VENDOR} (Manufacturer ID='${mfg:-?}')"
}

#######################################
# Whether active fan control is available for the detected vendor.
# Globals:
#   RAW_SET_PREFIX (read)
# Returns:
#   0 if control is possible, 1 otherwise.
#######################################
can_control() {
  [[ -n "$RAW_SET_PREFIX" ]]
}

#######################################
# Hand fan regulation back to the BMC automatic mode.
# Globals:
#   DRY_RUN, IPMITOOL, RAW_AUTO (read)
# Returns:
#   0 on success, non-zero on IPMI error.
#######################################
bmc_auto() {
  can_control || return 0
  if [[ "$DRY_RUN" == 1 ]]; then
    log "[dry-run] BMC automatic"
    return 0
  fi
  "$IPMITOOL" raw $RAW_AUTO >/dev/null 2>&1
}

#######################################
# Switch the BMC to manual fan control.
# Globals:
#   DRY_RUN, IPMITOOL, RAW_MANUAL (read)
# Returns:
#   0 on success, non-zero on IPMI error.
#######################################
bmc_manual() {
  can_control || return 0
  [[ "$DRY_RUN" == 1 ]] && return 0
  "$IPMITOOL" raw $RAW_MANUAL >/dev/null 2>&1
}

#######################################
# Set all fans to a given speed (manual mode must be active).
# Globals:
#   DRY_RUN, IPMITOOL, RAW_SET_PREFIX (read)
# Arguments:
#   $1 - speed as a decimal percent
# Returns:
#   0 on success, non-zero on IPMI error.
#######################################
bmc_set() {
  local hex
  hex=$(printf '0x%02x' "$1")
  if [[ "$DRY_RUN" == 1 ]]; then
    log "[dry-run] set fans to ${1}%"
    return 0
  fi
  "$IPMITOOL" raw $RAW_SET_PREFIX "$hex" >/dev/null 2>&1
}

#######################################
# Read every temperature sensor and derive the control state in one pass.
# Each controlling sensor is normalized against its own Upper-Critical, and the
# hottest normalized value drives the fan curve.
# Globals:
#   IPMITOOL, BASE_TEMP, SAFETY_MARGIN, HARD_MARGIN, CONTROL_UCR_MIN,
#   AMBIENT_MATCH (read)
# Outputs:
#   One line "MAXN=<0-100> HARD=<0|1> AMBIENT_HOT=<0|1> NCTRL=<n>" to stdout.
# Returns:
#   0 on success, 1 if IPMI returned nothing.
#######################################
read_state() {
  local out
  out=$("$IPMITOOL" sensor 2>/dev/null) || return 1
  [[ -n "$out" ]] || return 1
  awk -F'|' \
    -v base="$BASE_TEMP" -v smarg="$SAFETY_MARGIN" -v hmarg="$HARD_MARGIN" \
    -v umin="$CONTROL_UCR_MIN" -v amb="$AMBIENT_MATCH" '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
    {
      name = trim($1); reading = trim($2); unit = trim($3); ucr = trim($9)
    }
    unit ~ /degrees C/ && reading ~ /^[0-9]+(\.[0-9]+)?$/ {
      r = reading + 0
      has_ucr = (ucr ~ /^[0-9]+(\.[0-9]+)?$/)
      # Inlet-air guard: near-critical inlet forces a failsafe.
      if (name ~ amb && has_ucr && r >= (ucr + 0) - hmarg) ambient_hot = 1
      # Controlling sensors: a high Upper-Critical marks CPU-class sensors on
      # any vendor, which naturally excludes inlet and exhaust probes.
      if (has_ucr && (ucr + 0) >= umin) {
        nctrl++
        target = (ucr + 0) - smarg
        if (target > base) {
          n = (r - base) / (target - base)
          if (n < 0) n = 0
          if (n > 1) n = 1
          if (n > maxn) maxn = n
        }
        if (r >= (ucr + 0) - hmarg) hard = 1
      }
    }
    END {
      printf "MAXN=%d HARD=%d AMBIENT_HOT=%d NCTRL=%d\n", \
        int(maxn * 100 + 0.5), hard + 0, ambient_hot + 0, nctrl + 0
    }' <<<"$out"
}

#######################################
# Detect a failed fan (present but reading zero, or in a critical state).
# An unpopulated slot reports "ns" (no reading) and is ignored.
# Globals:
#   IPMITOOL (read)
# Returns:
#   0 if a fan failure is detected, 1 otherwise.
#######################################
fan_failed() {
  local out
  out=$("$IPMITOOL" sdr type fan 2>/dev/null) || return 1
  awk -F'|' '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
    {
      status = trim($3); val = trim($5)
      if (status == "ns") next
      rpm = val; sub(/ *RPM.*/, "", rpm)
      if (rpm ~ /^[0-9]+$/ && (rpm + 0) == 0) failed = 1
      if (status == "cr" || status == "nc") failed = 1
    }
    END { exit (failed ? 0 : 1) }' <<<"$out"
}

#######################################
# Map a normalized load to a fan speed percent within [MIN_PCT, MAX_PCT].
# Globals:
#   MIN_PCT, MAX_PCT (read)
# Arguments:
#   $1 - normalized load, 0-100
# Outputs:
#   The fan speed percent to stdout.
#######################################
pct_from_norm() {
  echo $(( MIN_PCT + ($1 * (MAX_PCT - MIN_PCT)) / 100 ))
}

#######################################
# Switch to BMC automatic mode, updating local state.
# Globals:
#   MODE, LAST_PCT (write)
#######################################
to_auto() {
  [[ "$MODE" == auto ]] && return 0
  if bmc_auto; then
    MODE=auto
    LAST_PCT=-1
  fi
}

#######################################
# Switch to manual mode, updating local state.
# Globals:
#   MODE (write)
#######################################
to_manual() {
  [[ "$MODE" == manual ]] && return 0
  bmc_manual && MODE=manual
}

#######################################
# Restore BMC automatic regulation on exit. Registered as an EXIT/INT/TERM trap.
#######################################
cleanup() {
  log "stopping -> restoring BMC automatic regulation"
  can_control && bmc_auto
}

#######################################
# Print discovered sensors, fans, vendor and computed state, then exit.
# Globals:
#   IPMITOOL, VENDOR (read)
# Outputs:
#   Human-readable diagnostics to stdout.
#######################################
do_check() {
  detect_vendor
  echo "--- Temperature sensors (ipmitool sensor) ---"
  "$IPMITOOL" sensor 2>/dev/null | awk -F'|' '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
    { u = trim($3) }
    u ~ /degrees C/ {
      printf "  %-22s reading=%-8s upper-crit=%s\n", trim($1), trim($2), trim($9)
    }'
  echo "--- Fans ---"
  "$IPMITOOL" sdr type fan 2>/dev/null | sed 's/^/  /'
  echo "--- Computed state ---"
  local state
  if state=$(read_state); then
    echo "  $state"
  else
    echo "  (IPMI read failed)"
  fi
  echo "--- Active control available? ---"
  if can_control; then
    echo "  yes (vendor=${VENDOR})"
  else
    echo "  no -> monitor mode (vendor ${VENDOR} not supported)"
  fi
}

#######################################
# Hand regulation back to the BMC and exit.
#######################################
do_restore() {
  detect_vendor
  if can_control; then
    bmc_auto && log "regulation handed back to the BMC (automatic)"
  else
    log "nothing to restore (vendor ${VENDOR})"
  fi
}

#######################################
# Handle an IPMI read failure: count it and fail safe past the threshold.
# Globals:
#   FAIL_COUNT (write), MAX_FAIL (read)
#######################################
handle_read_failure() {
  FAIL_COUNT=$((FAIL_COUNT + 1))
  log "IPMI read failed (${FAIL_COUNT}/${MAX_FAIL})"
  if [[ "$FAIL_COUNT" -ge "$MAX_FAIL" ]] && can_control; then
    to_auto
  fi
}

#######################################
# Apply one regulation decision from a parsed state.
# Globals:
#   MAXN, HARD, AMBIENT_HOT, NCTRL (read, set by eval of read_state)
#   ALLOW_DEGRADED, DEGRADED_MIN_PCT, MIN_PCT, MAX_PCT, HYST_PCT (read)
#   LAST_PCT, FAN_FAIL_LOGGED (write)
#######################################
regulate() {
  # Failsafes first: hand control back to the BMC.
  if [[ "$NCTRL" -eq 0 ]]; then
    log "no readable controlling sensor -> BMC automatic (safety)"
    to_auto
    return
  fi
  if [[ "$HARD" == 1 || "$AMBIENT_HOT" == 1 ]]; then
    log "thermal failsafe (hard=${HARD} ambient=${AMBIENT_HOT}) -> BMC automatic"
    to_auto
    return
  fi

  # A failed fan reverts to BMC automatic unless degraded mode is allowed.
  local floor="$MIN_PCT"
  if fan_failed; then
    if [[ "$ALLOW_DEGRADED" != 1 ]]; then
      if [[ "$FAN_FAIL_LOGGED" == 0 ]]; then
        log "failed fan -> BMC automatic (ALLOW_DEGRADED=0)"
        FAN_FAIL_LOGGED=1
      fi
      to_auto
      return
    fi
    floor="$DEGRADED_MIN_PCT"
    if [[ "$FAN_FAIL_LOGGED" == 0 ]]; then
      log "failed fan -> degraded mode, floor ${floor}%"
      FAN_FAIL_LOGGED=1
    fi
  else
    FAN_FAIL_LOGGED=0
  fi

  # Compute and apply the target speed with hysteresis.
  local pct
  pct=$(pct_from_norm "$MAXN")
  [[ "$pct" -lt "$floor" ]] && pct="$floor"
  [[ "$pct" -gt "$MAX_PCT" ]] && pct="$MAX_PCT"

  to_manual
  local delta=$(( pct > LAST_PCT ? pct - LAST_PCT : LAST_PCT - pct ))
  if [[ "$LAST_PCT" -lt 0 || "$delta" -ge "$HYST_PCT" ]]; then
    if bmc_set "$pct"; then
      log "load=${MAXN}% -> fans ${pct}%"
      LAST_PCT="$pct"
    else
      log "failed to set fan speed -> BMC automatic (safety)"
      to_auto
    fi
  fi
}

#######################################
# Run the control loop until terminated.
# Globals:
#   Most configuration and runtime state variables.
#######################################
run_daemon() {
  detect_vendor
  if ! can_control; then
    log "vendor not supported."
    if [[ "$REQUIRE_KNOWN_VENDOR" == 1 ]]; then
      log "REQUIRE_KNOWN_VENDOR=1 -> exiting"
      exit 0
    fi
    log "monitor mode: read-only, fans stay under BMC automatic control."
  fi
  # Restore BMC regulation on exit; a signal exits cleanly through that trap.
  trap cleanup EXIT
  trap 'exit 0' INT TERM
  log "starting (poll=${POLL_INTERVAL}s min=${MIN_PCT}% max=${MAX_PCT}%" \
    "base=${BASE_TEMP}C margin=${SAFETY_MARGIN}C)"

  local state
  while :; do
    if ! state=$(read_state); then
      handle_read_failure
      sleep "$POLL_INTERVAL"
      continue
    fi
    FAIL_COUNT=0
    # read_state emits "MAXN=.. HARD=.. AMBIENT_HOT=.. NCTRL=..".
    # shellcheck disable=SC2086
    eval "$state"

    if ! can_control; then
      log "monitor: load=${MAXN}% (controlling sensors=${NCTRL})"
      sleep "$POLL_INTERVAL"
      continue
    fi

    regulate
    sleep "$POLL_INTERVAL"
  done
}

#######################################
# Entry point: dispatch on the first argument.
# Arguments:
#   $1 - mode flag (default --daemon)
#######################################
main() {
  case "${1:---daemon}" in
    --check) do_check ;;
    --restore) do_restore ;;
    --dry-run) DRY_RUN=1; run_daemon ;;
    --once) detect_vendor; read_state ;;
    --daemon) run_daemon ;;
    *)
      echo "usage: fanctl [--daemon|--check|--dry-run|--restore|--once]" >&2
      exit 2
      ;;
  esac
}

main "$@"
