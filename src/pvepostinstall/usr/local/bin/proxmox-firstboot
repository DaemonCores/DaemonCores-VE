#!/bin/bash
# proxmox-firstboot — one-shot first-boot network bridge configuration.
#
# Purpose:
#   Detect the host's WAN interface (the one routing to the internet) and
#   bind it to the vmbr0 bridge declared in /etc/network/interfaces.
#
# Expected /etc/network/interfaces format:
#   The file must ship a placeholder `{{ WAN_DEVICE }}` inside the vmbr0
#   stanza (e.g. `bridge_ports {{ WAN_DEVICE }}`). This script resolves that
#   placeholder to the real interface name at first boot.
#
# Fallback logic:
#   `ip route get 8.8.8.8` is used to identify the default-route interface.
#   If 8.8.8.8 is unreachable (no route, offline lab, etc.), the command
#   fails and the script exits silently via `|| exit 0` so first boot is not
#   aborted — the bridge simply stays unconfigured and the admin can wire it
#   manually.
#
# Re-execution guard:
#   /var/lib/proxmox-firstboot-done is touched on success. The matching
#   systemd unit (proxmox-firstboot.service) is written so it only runs when
#   that flag file is absent, preventing re-execution on subsequent boots.
set -euo pipefail

WAN_IP="$(ip route get 8.8.8.8 \
    | awk -F"src " 'NR==1{split($2,a," ");print a[1]}'
)" || exit 0
WAN_DEVICE="$(ip -br a \
    | grep "${WAN_IP}" \
    | cut -d " " -f 1
)"

sed -i "s|{{ WAN_DEVICE }}|${WAN_DEVICE}|g" /etc/network/interfaces

touch /var/lib/proxmox-firstboot-done