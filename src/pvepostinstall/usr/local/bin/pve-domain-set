#!/bin/bash
# pve-domain-set — pin the host FQDN to its real IP in /etc/hosts.
#
# Purpose:
#   Resolve the host's first global IPv4 address and write an entry mapping
#   the FQDN (<short-hostname>.<domain>) and short hostname to that IP in
#   /etc/hosts. Stale entries for the same host are removed first to avoid
#   duplicates.
#
# Why Proxmox VE needs this:
#   Proxmox VE derives its cluster identity and API endpoint from the FQDN.
#   If /etc/hosts resolves the FQDN to 127.0.1.1 (Debian's default) instead
#   of the real LAN IP, pveproxy and the clustering layer can bind to the
#   loopback address, causing certificate mismatches, join failures and
#   unreachable Web UI on remote clients. Pinning the FQDN to the actual
#   network IP avoids those failure modes.
set -euo pipefail

IP=$(ip -4 addr show scope global | grep -oP "(?<=inet )[\d.]+" | head -1 || true)

if [[ -z "$IP" ]]; then
  exit 0
fi

HOST=$(hostname -s)
FQDN="${HOST}.$(hostname -d 2>/dev/null || echo local)"

sed -i "/^127\\.0\\.1\\.1.*${HOST}/d" /etc/hosts
sed -i "/${FQDN} ${HOST}/d" /etc/hosts
echo "${IP}    ${FQDN} ${HOST}" >> /etc/hosts